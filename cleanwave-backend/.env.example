# ============================================================
# FICHIER : .env.example
#
# Ce fichier est un MODÈLE.
# Copie-le en ".env" et remplis les vraies valeurs.
# Ne commite JAMAIS le fichier .env sur Git !
# ============================================================

# ──────────────────────────────────────────────────────────
# SERVEUR
# ──────────────────────────────────────────────────────────
# Port sur lequel le backend écoute
PORT=3001

# Environnement : "development" ou "production"
NODE_ENV=development

# ──────────────────────────────────────────────────────────
# BASE DE DONNÉES SUPABASE (pour Prisma)
# ──────────────────────────────────────────────────────────
# Où trouver ces valeurs ?
# → Supabase Dashboard → Settings → Database → Connection string
# → Choisir "Transaction pooler" (port 6543) pour DATABASE_URL
# → Choisir "Direct connection" (port 5432) pour DIRECT_URL

# URL de connexion via le pooler (utilisée par Prisma en production)
DATABASE_URL="postgresql://postgres.rnvyezzhdtbqodrecrpv:NeEBf3HFcpybO3RU@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# URL de connexion directe (utilisée pour les migrations Prisma)
DIRECT_URL="postgresql://postgres.rnvyezzhdtbqodrecrpv:NeEBf3HFcpybO3RU@aws-0-eu-west-1.pooler.supabase.com:5432/postgres"


# ──────────────────────────────────────────────────────────
# SUPABASE (pour vérifier les tokens JWT dans le backend)
# ──────────────────────────────────────────────────────────
# URL de ton projet Supabase (même valeur que dans supabase.js du frontend)
SUPABASE_URL="https://rnvyezzhdtbqodrecrpv.supabase.co"

