generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["auth", "public"]
}

model Profile {
  id                    String        @id @db.Uuid
  nom                   String        @db.VarChar(255)
  prenom                String?       @db.VarChar(255)
  email                 String        @unique(map: "profiles_email_unique") @db.VarChar(255)
  telephone             String?       @db.VarChar(20)
  type                  String        @default("citoyen") @db.VarChar(50)
  quartier              String?       @db.VarChar(255)
  avatar_url            String?
  created_at            DateTime?     @default(now()) @db.Timestamptz(6)
  updated_at            DateTime?     @default(now()) @updatedAt @db.Timestamptz(6)
  localisation_id       BigInt?
  chat_messages         ChatMessage[]
  collecteurs_geres     Collecteur[]  @relation("PartenaireCollecteurs")
  fiche_collecteur      Collecteur?   @relation("ProfileCollecteur")
  itineraires_crees     Itineraire[]  @relation("PartenaireItineraires")
  plannings_crees       Planning[]    @relation("PartenaireplanningS")
  primes                Prime[]       @relation("CitoyenPrimes")
  users                 users         @relation(fields: [id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  localisation          Localisation? @relation(fields: [localisation_id], references: [id], onUpdate: NoAction)
  signalements_assignes Signalement[] @relation("CollecteurSignalements")
  signalements_emis     Signalement[] @relation("CitoyenSignalements")
  settings              UserSettings?

  @@index([localisation_id], map: "idx_profiles_localisation")
  @@index([type], map: "idx_profiles_type")
  @@map("profiles")
  @@schema("public")
}

model Localisation {
  id                BigInt           @id @default(autoincrement())
  nom               String           @unique @db.VarChar(150)
  ville             String           @db.VarChar(100)
  description       String?
  latitude          Decimal?         @db.Decimal(10, 8)
  longitude         Decimal?         @db.Decimal(11, 8)
  est_active        Boolean          @default(true)
  created_at        DateTime         @default(now()) @db.Timestamptz(6)
  updated_at        DateTime         @default(now()) @updatedAt @db.Timestamptz(6)
  depots            Depot[]
  etapes            EtapePlanning[]
  arrets_itineraire ItineraireStop[]
  profiles          Profile[]
  signalements      Signalement[]

  @@map("localisations")
  @@schema("public")
}

model Collecteur {
  id            BigInt       @id @default(autoincrement())
  profile_id    String       @unique @db.Uuid
  partenaire_id String       @db.Uuid
  matricule     String?      @db.VarChar(50)
  est_actif     Boolean      @default(true)
  created_at    DateTime     @default(now()) @db.Timestamptz(6)
  updated_at    DateTime     @default(now()) @updatedAt @db.Timestamptz(6)
  partenaire    Profile      @relation("PartenaireCollecteurs", fields: [partenaire_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  profile       Profile      @relation("ProfileCollecteur", fields: [profile_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  itineraires   Itineraire[]

  @@index([partenaire_id], map: "idx_collecteurs_partenaire")
  @@map("collecteurs")
  @@schema("public")
}

model Depot {
  id                BigInt           @id @default(autoincrement())
  latitude          Decimal          @db.Decimal(10, 8)
  longitude         Decimal          @db.Decimal(11, 8)
  quartier          String?          @db.VarChar(255)
  nom               String?          @db.VarChar(255)
  type_dechets      String?          @default("tous") @db.VarChar(255)
  est_actif         Boolean?         @default(true)
  created_at        DateTime?        @default(now()) @db.Timestamptz(6)
  updated_at        DateTime?        @default(now()) @updatedAt @db.Timestamptz(6)
  localisation_id   BigInt?
  description       String?
  localisation      Localisation?    @relation(fields: [localisation_id], references: [id], onUpdate: NoAction)
  arrets_itineraire ItineraireStop[]
  signalements      Signalement[]

  @@map("depots")
  @@schema("public")
}

model TypeDechet {
  id           BigInt                  @id @default(autoincrement())
  nom          String                  @unique @db.VarChar(100)
  description  String?
  icone        String?                 @db.VarChar(50)
  couleur      String?                 @db.VarChar(7)
  est_actif    Boolean                 @default(true)
  created_at   DateTime                @default(now()) @db.Timestamptz(6)
  signalements SignalementTypeDechet[]

  @@map("types_dechets")
  @@schema("public")
}

model Signalement {
  id                   BigInt                  @id @default(autoincrement())
  user_id              String                  @db.Uuid
  collecteur_id        String?                 @db.Uuid
  depot_id             BigInt?
  localisation         String?
  latitude             Decimal?                @db.Decimal(10, 8)
  longitude            Decimal?                @db.Decimal(11, 8)
  description          String?
  type_signalement     String                  @default("carte") @db.VarChar(50)
  etat                 StatutSignalement
  etat_prise_en_charge String                  @default("non_valide") @db.VarChar(50)
  photo_url            String?
  date_signalement     DateTime                @default(now()) @db.Timestamptz(6)
  date_prise_en_charge DateTime?               @db.Timestamptz(6)
  created_at           DateTime?               @default(now()) @db.Timestamptz(6)
  updated_at           DateTime?               @default(now()) @updatedAt @db.Timestamptz(6)
  date_resolution      DateTime?               @db.Timestamptz(6)
  localisation_id      BigInt?
  types_dechets        SignalementTypeDechet[]
  collecteur           Profile?                @relation("CollecteurSignalements", fields: [collecteur_id], references: [id], onUpdate: NoAction)
  depot                Depot?                  @relation(fields: [depot_id], references: [id], onUpdate: NoAction)
  quartier             Localisation?           @relation(fields: [localisation_id], references: [id], onUpdate: NoAction)
  citoyen              Profile                 @relation("CitoyenSignalements", fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([collecteur_id], map: "idx_signalements_collecteur")
  @@index([date_signalement(sort: Desc)], map: "idx_signalements_date")
  @@index([etat], map: "idx_signalements_etat")
  @@index([user_id], map: "idx_signalements_user_id")
  @@map("signalements")
  @@schema("public")
}

model SignalementTypeDechet {
  signalement_id BigInt
  type_dechet_id BigInt
  signalement    Signalement @relation(fields: [signalement_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  type_dechet    TypeDechet  @relation(fields: [type_dechet_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([signalement_id, type_dechet_id])
  @@index([type_dechet_id], map: "idx_sig_type_dechet")
  @@index([signalement_id], map: "idx_sig_type_signalement")
  @@map("signalement_type_dechet")
  @@schema("public")
}

model Planning {
  id             BigInt          @id @default(autoincrement())
  partenaire_id  String          @db.Uuid
  date_collecte  DateTime        @db.Date
  heure_debut    DateTime        @db.Time(6)
  heure_fin      DateTime        @db.Time(6)
  zone_collecte  String          @db.VarChar(255)
  camion_assigne String?         @db.VarChar(255)
  notes          String?
  statut         StatutPlanning
  created_at     DateTime?       @default(now()) @db.Timestamptz(6)
  updated_at     DateTime?       @default(now()) @updatedAt @db.Timestamptz(6)
  titre          String?         @db.VarChar(200)
  etapes         EtapePlanning[]
  itineraires    Itineraire[]
  partenaire     Profile         @relation("PartenaireplanningS", fields: [partenaire_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([date_collecte], map: "idx_plannings_date")
  @@index([partenaire_id], map: "idx_plannings_partenaire")
  @@index([statut], map: "idx_plannings_statut")
  @@map("plannings")
  @@schema("public")
}

model EtapePlanning {
  id              BigInt       @id @default(autoincrement())
  planning_id     BigInt
  localisation_id BigInt
  heure_debut     String       @db.VarChar(5)
  heure_fin       String       @db.VarChar(5)
  ordre           Int          @default(0)
  notes           String?
  created_at      DateTime     @default(now()) @db.Timestamptz(6)
  localisation    Localisation @relation(fields: [localisation_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  planning        Planning     @relation(fields: [planning_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([localisation_id], map: "idx_etapes_localisation")
  @@index([planning_id], map: "idx_etapes_planning")
  @@map("etapes_planning")
  @@schema("public")
}

model Itineraire {
  id            BigInt           @id @default(autoincrement())
  partenaire_id String           @db.Uuid
  collecteur_id BigInt
  planning_id   BigInt?
  titre         String           @db.VarChar(200)
  description   String?
  date_debut    DateTime         @db.Date
  statut        StatutItineraire @default(brouillon)
  date_envoi    DateTime?        @db.Timestamptz(6)
  created_at    DateTime         @default(now()) @db.Timestamptz(6)
  updated_at    DateTime         @default(now()) @updatedAt @db.Timestamptz(6)
  arrets        ItineraireStop[]
  collecteur    Collecteur       @relation(fields: [collecteur_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  partenaire    Profile          @relation("PartenaireItineraires", fields: [partenaire_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  planning      Planning?        @relation(fields: [planning_id], references: [id], onUpdate: NoAction)

  @@index([collecteur_id], map: "idx_itineraires_collecteur")
  @@map("itineraires")
  @@schema("public")
}

model ItineraireStop {
  id              BigInt        @id @default(autoincrement())
  itineraire_id   BigInt
  localisation_id BigInt?
  depot_id        BigInt?
  ordre           Int           @default(0)
  heure_passage   String?       @db.VarChar(5)
  notes           String?
  est_valide      Boolean       @default(false)
  date_validation DateTime?     @db.Timestamptz(6)
  created_at      DateTime      @default(now()) @db.Timestamptz(6)
  depot           Depot?        @relation(fields: [depot_id], references: [id], onUpdate: NoAction)
  itineraire      Itineraire    @relation(fields: [itineraire_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  localisation    Localisation? @relation(fields: [localisation_id], references: [id], onUpdate: NoAction)

  @@index([itineraire_id], map: "idx_itineraire_stops_itineraire")
  @@map("itineraire_stops")
  @@schema("public")
}

model Prime {
  id             BigInt      @id @default(autoincrement())
  citoyen_id     String      @db.Uuid
  montant        Decimal     @db.Decimal(10, 2)
  motif          String
  statut         StatutPrime @default(en_attente)
  date_prime     DateTime    @default(now()) @db.Timestamptz(6)
  date_versement DateTime?   @db.Timestamptz(6)
  created_at     DateTime    @default(now()) @db.Timestamptz(6)
  updated_at     DateTime    @default(now()) @updatedAt @db.Timestamptz(6)
  citoyen        Profile     @relation("CitoyenPrimes", fields: [citoyen_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([citoyen_id], map: "idx_primes_citoyen")
  @@index([statut], map: "idx_primes_statut")
  @@map("primes")
  @@schema("public")
}

model UserSettings {
  id                  BigInt   @id @default(autoincrement())
  profile_id          String   @unique @db.Uuid
  dark_mode           Boolean  @default(false)
  notifications_push  Boolean  @default(true)
  notifications_email Boolean  @default(false)
  langue              String   @default("fr") @db.VarChar(5)
  created_at          DateTime @default(now()) @db.Timestamptz(6)
  updated_at          DateTime @default(now()) @updatedAt @db.Timestamptz(6)
  profile             Profile  @relation(fields: [profile_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("user_settings")
  @@schema("public")
}

model ChatMessage {
  id         BigInt    @id @default(autoincrement())
  user_id    String    @db.Uuid
  role       String    @db.VarChar(20)
  contenu    String
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  user       Profile   @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("chat_messages")
  @@schema("public")
}

